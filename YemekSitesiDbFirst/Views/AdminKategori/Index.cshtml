@model IEnumerable<YemekSitesiDbFirst.Models.Kategoriler>

@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Kategoriler</h1>

<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item active">Kategori Listesi</li>
</ol>

<a href="/AdminKategori/Create" class="btn btn-primary mb-3">
    Yeni Kategori Ekle
</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Kategori Id</th>
            <th>Kategori Adı</th>
            <th>Açıklama</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.KategoriId</td>
                <td>@item.KategoriAd</td>
                <td>@item.Aciklama</td>
                <td>
                    <a href="/AdminKategori/Edit/@item.KategoriId" class="btn btn-warning btn-sm">
                        Güncelle
                    </a>

                    <a href="/AdminKategori/Delete/@item.KategoriId" class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>