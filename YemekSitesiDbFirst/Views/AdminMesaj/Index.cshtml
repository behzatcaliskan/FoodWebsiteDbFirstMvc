@model IEnumerable<YemekSitesiDbFirst.Models.Mesajlar>

@{
    ViewData["Title"] = "Mesajlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Mesajlar</h1>

<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item active">Gelen Mesajlar</li>
</ol>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ad Soyad</th>
            <th>Mail</th>
            <th>Konu</th>
            <th>Tarih</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.MesajId</td>
                <td>@item.AdSoyad</td>
                <td>@item.Mail</td>
                <td>@item.Konu</td>
                <td>@item.Tarih</td>
                <td>
                    <a href="/AdminMesaj/Details/@item.MesajId" class="btn btn-info btn-sm">
                        Detay
                    </a>

                    <a href="/AdminMesaj/Delete/@item.MesajId" class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>