@model YemekSitesiDbFirst.Models.Mesajlar

@{
    ViewData["Title"] = "Mesaj Detay";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Mesaj Detay</h1>

<table class="table table-bordered">
    <tr>
        <th>Mesaj ID</th>
        <td>@Model.MesajId</td>
    </tr>

    <tr>
        <th>Ad Soyad</th>
        <td>@Model.AdSoyad</td>
    </tr>

    <tr>
        <th>Mail</th>
        <td>@Model.Mail</td>
    </tr>

    <tr>
        <th>Konu</th>
        <td>@Model.Konu</td>
    </tr>

    <tr>
        <th>Tarih</th>
        <td>@Model.Tarih</td>
    </tr>

    <tr>
        <th>Mesaj</th>
        <td>@Model.MesajIcerik</td>
    </tr>
</table>

<a href="/AdminMesaj/Index" class="btn btn-secondary">
    Geri Dön
</a>