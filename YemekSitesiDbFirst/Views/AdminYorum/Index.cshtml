@model IEnumerable<YemekSitesiDbFirst.Models.Yorumlar>

@{
    ViewData["Title"] = "Yorumlar";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h1 class="mt-4">Yorumlar</h1>

<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item active">Yorum Listesi</li>
</ol>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ad Soyad</th>
            <th>Mail</th>
            <th>Yemek</th>
            <th>Yorum</th>
            <th>Tarih</th>
            <th>Durum</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.YorumId</td>
                <td>@item.AdSoyad</td>
                <td>@item.Mail</td>
                <td>@item.Yemek?.YemekAd</td>
                <td>@item.YorumIcerik</td>
                <td>@item.Tarih</td>
                <td>
                    @if (item.Durum == true)
                    {
                        <span class="badge bg-success">Onaylı</span>
                    }
                    else
                    {
                        <span class="badge bg-warning text-dark">Onay Bekliyor</span>
                    }
                </td>
                <td>
                    @if (item.Durum == true)
                    {
                        <a href="/AdminYorum/PasifYap/@item.YorumId" class="btn btn-secondary btn-sm">
                            Pasif Yap
                        </a>
                    }
                    else
                    {
                        <a href="/AdminYorum/Onayla/@item.YorumId" class="btn btn-success btn-sm">
                            Onayla
                        </a>
                    }

                    <a href="/AdminYorum/Delete/@item.YorumId" class="btn btn-danger btn-sm">
                        Sil
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>